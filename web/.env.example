ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_SESSION_SECRET=replace_with_a_long_random_string

CUSTOMER_SESSION_SECRET=replace_with_a_different_long_random_string

# Optional -- leave blank to disable Stripe at checkout (Cash on Delivery
# still works with no keys set). Fill in real test keys from
# https://dashboard.stripe.com/test/apikeys to enable it.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Used to build the Stripe redirect URLs (success/cancel) -- change if you
# run the dev server on a different port or a real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
